# Neon connection string — copy from your Neon project dashboard.
# Use sslmode=verify-full (recommended by pg v9 migration guide) instead of sslmode=require
# Format: postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=verify-full
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full

YOUTUBE_API_KEY=your_youtube_data_api_v3_key
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key_optional
LLM_PROVIDER=gemini
NODE_ENV=development
PORT=3000

# Set to "false" only for a local Postgres instance that has no SSL.
# Leave as "true" (or unset) when connecting to Neon or any cloud Postgres.
DATABASE_SSL=true
